{
    "name": "wedgesama/form-attribute-bundle",
    "type": "symfony-bundle",
    "description": "Use PHP attributes as form configuration in Symfony",
    "keywords": ["symfony", "form", "attributes", "annotations"],
    "license": "MIT",
    "authors": [
        {
            "name": "Benjamin Georgeault",
            "email": "git@wedgesama.fr"
        }
    ],
    "require": {
        "php": ">=8.4",
        "symfony/config": "^7.4|^8.0",
        "symfony/dependency-injection": "^7.4|^8.0",
        "symfony/form": "^7.4|^8.0",
        "symfony/http-kernel": "^7.4|^8.0"
    },
    "autoload": {
        "psr-4": {
            "WS\\Bundle\\FormAttributeBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WS\\Bundle\\FormAttributeBundle\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    }
}
